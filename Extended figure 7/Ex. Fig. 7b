make_mat_from_wide <- function(df, ko_vec, suffix, row_col = "GTDB"){
cols_use <- paste0(ko_vec, "_", suffix)

miss_cols <- setdiff(cols_use, colnames(df))
if(length(miss_cols) > 0){
stop("缺少这些列: ", paste(miss_cols, collapse = ", "))
}

mat <- df[, c(row_col, cols_use)] %>%
tibble::column_to_rownames(row_col) %>%
as.matrix()

mode(mat) <- "numeric"
colnames(mat) <- ko_vec
return(mat)
}

