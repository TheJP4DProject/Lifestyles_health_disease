make_wide <- function(df, features, metas, value_col){
df %>%
filter(feature %in% features, metadata %in% metas) %>%
select(feature, metadata, all_of(value_col)) %>%
pivot_wider(names_from = metadata, values_from = all_of(value_col)) %>%
column_to_rownames("feature") %>%
.[features[features %in% rownames(.)],
metas[metas %in% colnames(.)], drop = FALSE]
}

