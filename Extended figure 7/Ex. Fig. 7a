library(tidyverse)
library(ComplexHeatmap)
library(circlize)
library(grid)
library(openxlsx)

ko_labels <- c(
"K12308" = "lactose degradation K12308",
"K00849" = "Galactokinase K00849",
"K00925" = "acetate kinase K00925",
"K00016" = "lactate dehydrogenase K00016",
"K00248" = "butyryl-CoA dehydrogenase K00248"
)

cor_sub <- read.xlsx("Supplementary Tables_260405.xlsx",
sheet="Sfig.7A_data",
check.names = F,
sep.names = " ")

sp_list <- unique(cor_sub$GTDB)
ko_list <- unique(cor_sub$KO)

mat_rho <- cor_sub %>%
select(GTDB, KO, Rho) %>%
pivot_wider(names_from = KO, values_from = Rho) %>%
column_to_rownames("GTDB") %>%
.[sp_list, ko_list, drop = FALSE] %>%
as.matrix()

mat_p <- cor_sub %>%
select(GTDB, KO, P) %>%
pivot_wider(names_from = KO, values_from = P) %>%
column_to_rownames("GTDB") %>%
.[rownames(mat_rho), colnames(mat_rho), drop = FALSE] %>%
as.matrix()

mat_q <- cor_sub %>%
select(GTDB, KO, FDR) %>%
pivot_wider(names_from = KO, values_from = FDR) %>%
column_to_rownames("GTDB") %>%
.[rownames(mat_rho), colnames(mat_rho), drop = FALSE] %>%
as.matrix()

mat_rho[is.na(mat_rho)] <- 0
mat_p[is.na(mat_p)] <- 1
mat_q[is.na(mat_q)] <- 1

rownames(mat_rho) <- gsub("\[ID:(\d+)\]", "\1", rownames(mat_rho))
rownames(mat_p) <- rownames(mat_rho)
rownames(mat_q) <- rownames(mat_rho)

mat_rho=mat_rho[,names(ko_labels)]
mat_p=mat_p[,names(ko_labels)]
mat_q=mat_q[,names(ko_labels)]

colnames(mat_rho) <- ko_labels[colnames(mat_rho)]
colnames(mat_p) <- ko_labels[colnames(mat_p)]
colnames(mat_q) <- ko_labels[colnames(mat_q)]

col_fun_rho <- colorRamp2(
c(-0.5,-0.3,-0.1,0,0.1,0.3,0.5),
c("#1a3a5c","#2d6a9f","#a8c8e8","white","salmon1","salmon2","salmon3")
)

legend_param_rho <- list(
title_gp = gpar(fontsize=5),
labels_gp = gpar(fontsize=5),
grid_height = unit(1.75,"mm"),
grid_width = unit(1.75,"mm"),
legend_height = unit(14,"mm"),
at = c(-0.5,-0.3,0,0.3,0.5),
tick_length = unit(0.5,"mm"),
background_gp = gpar(lwd=0.25)
)

make_cell_fun_spearman <- function(qmat, pmat){
function(j, i, x, y, width, height, fill){
q <- qmat[i,j]
p <- pmat[i,j]
if(!is.na(q) && q < 0.05){
grid.text("**", x, y, gp=gpar(fontsize=5))
} else if(!is.na(p) && p < 0.05){
grid.text("*", x, y, gp=gpar(fontsize=5))
}
}
}

hm_main <- Heatmap(
mat_rho,
name = "*P < 0.05, **FDR < 0.05\nSpearman’s rho",
cluster_columns = FALSE,
cluster_rows = FALSE,
col = col_fun_rho,
row_names_side = "left",
show_row_names = TRUE,
show_column_names = TRUE,
column_names_rot = 60,
column_title_gp = gpar(fontsize=5),
column_names_gp = gpar(fontsize=5),
row_names_gp = gpar(fontsize=5),
height = nrow(mat_rho) * unit(2.5,"mm"),
width = ncol(mat_rho) * unit(2.5,"mm"),
heatmap_legend_param = legend_param_rho,
cell_fun = make_cell_fun_spearman(mat_q, mat_p)
)

pdf("Sfig7A.pdf", width = 6, height = 8)
draw(hm_main)
dev.off()