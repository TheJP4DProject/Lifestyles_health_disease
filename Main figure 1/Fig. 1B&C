row1 <- arrangeGrob(grobs = plots_cytokine[1:4], ncol = 4)
row2 <- arrangeGrob(grobs = c(plots_cytokine[5:7], list(legend_grob)), ncol = 4)
row3 <- arrangeGrob(grobs = plots_metabo, ncol = 4)

pdf("output_figure.pdf", width = 2.5, height = 3)
grid.arrange(row1, row2, row3, nrow = 3)
dev.off()

calc_summary <- function(data_df, metadata_df, targets) {

  targets_exist <- intersect(targets, colnames(data_df))
  if (length(targets_exist) == 0) return(NULL)

  common_ids <- intersect(rownames(data_df), rownames(metadata_df))
  data_df <- data_df[common_ids, ]
  health_vec <- metadata_df[common_ids, "General.Health"]

  res_list <- list()

  for (tgt in targets_exist) {

    vals <- data_df[, tgt]
    min_nz <- suppressWarnings(min(vals[vals > 0], na.rm = TRUE))
    vals[vals == 0] <- min_nz / 2

    df <- data.frame(value = vals, health = health_vec) %>%
      filter(!is.na(value) & !is.na(health) & value > 0)

    df0 <- df[df$health == 0, "value"]
    df1 <- df[df$health == 1, "value"]

    med0 <- median(df0, na.rm = TRUE)
    med1 <- median(df1, na.rm = TRUE)

    p_val <- tryCatch(wilcox.test(df0, df1)$p.value,
                      error = function(e) NA)

    log2fc <- ifelse(
      is.na(med0) | is.na(med1) | med0 <= 0 | med1 <= 0,
      NA, log2(med1 / med0)
    )

    res_list[[tgt]] <- data.frame(
      Feature = tgt,
      median_Health0 = med0,
      sd_Health0 = sd(df0, na.rm = TRUE),
      n_Health0 = sum(!is.na(df0)),
      median_Health1 = med1,
      sd_Health1 = sd(df1, na.rm = TRUE),
      n_Health1 = sum(!is.na(df1)),
      log2FC_Health1_vs_0 = log2fc,
      p_value = p_val
    )
  }

  do.call(rbind, res_list)
}

summary_cytokine <- calc_summary(cytokine, metadata, target_cytokines)
summary_metabo   <- calc_summary(metabo, metadata, target_metabos)

write.csv(summary_cytokine, "cytokine_summary.csv", row.names = FALSE)
write.csv(summary_metabo,   "metabo_summary.csv",   row.names = FALSE)
