  rectGrob(x = 0.1, y = 0.45, width = 0.12, height = 0.12,
           gp = gpar(fill = COLOR_HEALTH1, col = "black", lwd = 0.4)),
  textGrob("Health = 1", gp = gpar(fontsize = 5),
           x = 0.28, y = 0.51, just = c(0, 0.5))
