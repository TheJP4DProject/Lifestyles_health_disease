colnames(tempworld <- sub(".v3_([0-9]{5})\].", "\1", colnames(tempworld)))
tempworld <- standardize_cols(clr_transform(tempworld))

rds_file <- "model_results_1se_logodds/rds_files/General.Health_sp.rds"

