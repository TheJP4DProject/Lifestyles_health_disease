
rm(list=ls())
set.seed(100)

library(tidyverse)
library(openxlsx)
library(circlize)
library(ComplexHeatmap)
library(htmlwidgets)
library(htmltools)
library(networkD3)


ordered_df <- data.frame(
  group = c(
    "Vegetables", "Fruits", "Mushrooms",
    "Coffee", "Green tea", "Vinegar",
    "Tofu", "Natto", "Miso",
    "Pickles", "Kimchi", "Yogurt",
    "Milk", "Meat", "Processed meat", "Seafood",
    "Eggs", "Dressing", "Rice", "Bread", "Noodles", "Soft drinks",
    "Alcohol", "Smoking",
    "Strong physical activity", "Moderate physical activity",
    "Weak physical activity", "Sitting down ≥ 9.5h"
  ),
  annotation = c(
    rep("Plant-based diets", times = 3),
    rep("Polyphenol-rich beverages", times = 2),
    rep("NO diets", times = 2),
    rep("Fermented diets", times = 4),
    rep("Dairy product", times = 2),
    rep("Animal-based diets", times = 5),
    rep("Starch/Sugar-rich diets", times = 4),
    rep("Alcohol/Smoking", times = 2),
    rep("Exercise", times = 4)
  ),
  color = c(
    rep("#66c2a5", times = 3),
    rep("#b3b3b3", times = 2),
    rep("white", times = 2),
    rep("#fc8d62", times = 4),
    rep("#8da0cb", times = 2),
    rep("#e78ac3", times = 5),
    rep("#a6d854", times = 4),
    rep("#ffd92f", times = 2),
    rep("#e5c494", times = 4)
  )
)
rownames(ordered_df) <- ordered_df$group


Disease_list <- data.frame(
  group = c(
    "General health", "Inflammatory Bowel Disease (IBD)",
    "Irritable Bowel Syndrome (IBS)", "Liver cirrhosis",
    "Type 2 Diabetes (T2D)", "Dyslipidemia", "Hypertension",
    "Hyperuricemia", "Ischemic Heart Disease (IHD)",
    "Heart failure", "Stroke", "Depression",
    "Rheumatoid arthritis", "Collagen disease",
    "Asthma", "Chronic Obstructive Pulmonary Disease (COPD)"
  ),
  color = c("white", rep("black", 15))
)

##### Parameters #####
sankeywidth  <- 850
sankeyheight <- 600


causal <- read.xlsx("supplementary_tables.xlsx",
                    sheet = "S9_MOTU",
                    check.names = FALSE,
                    sep.names = " ")

colnames(causal)[6] <- "Mediator"


sp_list <- read.xlsx("supplementary_tables.xlsx",
                     sheet = "S13_TOP25",
                     check.names = FALSE,
                     sep.names = " ")

top25 <- sp_list$GTDB[1:25]

causal_filtered <- causal[causal$Mediator %in% top25, ]
causal_filtered$ori <- causal_filtered$Mediator
causal_filtered$Mediator <- gsub("\\[ID:(\\d+)\\]", "\\1", causal_filtered$Mediator)

top25_id <- gsub("\\[ID:(\\d+)\\]", "\\1", top25)
key <- top25_id[top25_id %in% unique(causal_filtered$Mediator)]


condi <- "TOP25_newfig3C"

causal_filtered$ExposureClass <- ordered_df[causal_filtered$Exposure, ]$annotation

nodes <- data.frame()

temp_factor <- unique(ordered_df[ordered_df$group %in% causal_filtered$Exposure, ]$group)

nodes <- rbind(nodes, data.frame(
  id = 0:(length(temp_factor)-1),
  tag = temp_factor,
  display_tag = temp_factor,
  group = ordered_df[temp_factor, ]$annotation
))

temp_sp <- key

nodes <- rbind(nodes, data.frame(
  id = 0:(length(temp_sp)-1) + nrow(nodes),
  tag = temp_sp,
  display_tag = temp_sp,
  group = "all_nodes"
))

disease_display_names <- sapply(Disease_list$group, function(x) {
  if (grepl("\\(.*\\)", x)) {
    substr(x, regexpr("\\(", x)+1, regexpr("\\)", x)-1)
  } else x
})

temp_dis <- Disease_list$group[Disease_list$group %in% unique(causal_filtered$Outcome)]

nodes <- rbind(nodes, data.frame(
  id = 0:(length(temp_dis)-1) + nrow(nodes),
  tag = temp_dis,
  display_tag = disease_display_names[temp_dis],
  group = ifelse(temp_dis == "General health", "Health", "Disease")
))

links <- data.frame()

# Exposure -> Mediator
for (i in temp_factor) {
  for (j in temp_sp) {

    tmp <- causal_filtered[causal_filtered$Exposure==i &
                             causal_filtered$EXP_coef>0 &
                             causal_filtered$Mediator==j, ]
    if (nrow(tmp)>0) {
      links <- rbind(links,
                     data.frame(source=i,target=j,val=nrow(tmp),
                                ids=nodes$id[nodes$tag==i],
                                idt=nodes$id[nodes$tag==j],
                                group="Plus"))
    }

    tmp <- causal_filtered[causal_filtered$Exposure==i &
                             causal_filtered$EXP_coef<0 &
                             causal_filtered$Mediator==j, ]
    if (nrow(tmp)>0) {
      links <- rbind(links,
                     data.frame(source=i,target=j,val=nrow(tmp),
                                ids=nodes$id[nodes$tag==i],
                                idt=nodes$id[nodes$tag==j],
                                group="Minus"))
    }
  }
}

# Mediator -> Outcome
for (i in temp_sp) {
  for (j in temp_dis) {

    tmp <- causal_filtered[causal_filtered$Outcome==j &
                             causal_filtered$Dis_coef>0 &
                             causal_filtered$Mediator==i, ]
    if (nrow(tmp)>0) {
      links <- rbind(links,
                     data.frame(source=i,target=j,val=nrow(tmp),
                                ids=nodes$id[nodes$tag==i],
                                idt=nodes$id[nodes$tag==j],
                                group="Plus"))
    }

    tmp <- causal_filtered[causal_filtered$Outcome==j &
                             causal_filtered$Dis_coef<0 &
                             causal_filtered$Mediator==i, ]
    if (nrow(tmp)>0) {
      links <- rbind(links,
                     data.frame(source=i,target=j,val=nrow(tmp),
                                ids=nodes$id[nodes$tag==i],
                                idt=nodes$id[nodes$tag==j],
                                group="Minus"))
    }
  }
}



all_color_domain <- c("Plant-based diets","Polyphenol-rich beverages",
                      "NO diets","Fermented diets","Dairy product",
                      "Animal-based diets","Starch/Sugar-rich diets",
                      "Alcohol/Smoking","Exercise",
                      "Health","Disease","Plus","Minus","all_nodes")

all_color_range <- c("#66c2a5","#b3b3b3","white","#fc8d62","#8da0cb",
                     "#e78ac3","#a6d854","#ffd92f","#e5c494",
                     "white","black","#eca19c","#9cc4ea","black")

existing_groups <- unique(c(nodes$group, links$group))
color_map <- setNames(all_color_range, all_color_domain)
existing_colors <- color_map[existing_groups]
existing_colors <- existing_colors[!is.na(existing_colors)]

domain_str <- paste0('["', paste(names(existing_colors), collapse='","'), '"]')
range_str  <- paste0('["', paste(existing_colors, collapse='","'), '"]')

my_color <- paste0(
  'd3.scaleOrdinal().domain(', domain_str, ').range(', range_str, ')'
)


p <- sankeyNetwork(
  Links = links,
  Nodes = nodes,
  Source = "ids",
  Target = "idt",
  Value = "val",
  NodeID = "display_tag",
  colourScale = my_color,
  LinkGroup = "group",
  NodeGroup = "group",
  fontSize = 16,
  fontFamily = "helvetica",
  iterations = 0,
  sinksRight = FALSE,
  width = sankeywidth,
  height = sankeyheight,
  nodeWidth = 2
)

p <- htmlwidgets::prependContent(
  p,
  htmltools::tags$h1(condi,
                      style="text-align:center;")
)

saveNetwork(p, paste0(condi, ".html"))

message("Done: ", condi, ".html")



sp_anno <- read.xlsx("supplementary_tables.xlsx",
                     sheet="S13_TOP25")

sp_anno$ID_clean <- gsub("\\[ID:(\\d+)\\]", "\\1", sp_anno$GTDB)

disease_map_full <- setNames(
  Disease_list$group,
  sapply(Disease_list$group, function(x){
    if (grepl("\\(.*\\)", x))
      substr(x, regexpr("\\(",x)+1, regexpr("\\)",x)-1)
    else x
  })
)

valid_exp_med <- links %>%
  filter(source %in% ordered_df$group & target %in% key)

valid_med_dis <- links %>%
  filter(source %in% key & target %in% Disease_list$group)

valid_triplets <- causal_filtered %>%
  semi_join(valid_exp_med, by=c("Exposure","Mediator")) %>%
  semi_join(valid_med_dis, by=c("Mediator","Outcome"))

out_pairs <- valid_triplets %>%
  left_join(sp_anno, by=c("Mediator"="ID_clean")) %>%
  mutate(Outcome = disease_map_full[Outcome])

write.csv(causal_filtered, "<out_dir>/fig3C.csv", row.names=FALSE)
write.csv(out_pairs, "<out_dir>/fig3D.csv", row.names=FALSE)

message("Saved outputs")