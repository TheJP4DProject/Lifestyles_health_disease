
library(openxlsx)
library(tidyverse)
library(circlize)
library(ComplexHeatmap)
library(htmlwidgets)
library(htmltools)
library(networkD3)

ordered_df <- data.frame(
  group = c(
    "Vegetables", "Fruits", "Mushrooms",
    "Coffee", "Green tea", "Vinegar",
    "Tofu", "Natto", "Miso",
    "Pickles", "Kimchi", "Yogurt",
    "Milk", "Meat", "Processed meat", "Seafood",
    "Eggs", "Dressing", "Rice", "Bread", "Noodles", "Soft drinks",
    "Alcohol", "Smoking", "Weak physical activity", "Moderate physical activity",
    "Strong physical activity", "Sitting down ≥ 9.5h"
  ),
  annotation = c(
    rep("Plant-based diets", times = 3),
    rep("Polyphenol-rich beverages", times = 2),
    rep("-", times = 2),
    rep("Fermented diets", times = 4),
    rep("Dairy product", times = 2),
    rep("Animal-based diets", times = 5),
    rep("Starch/Sugar-rich diets", times = 4),
    rep("Alcohol/Smoking", times = 2),
    rep("Exercise", times = 4)
  ),
  color = c(
    rep("#66c2a5", times = 3),
    rep("#b3b3b3", times = 2),
    rep("white", times = 2),
    rep("#fc8d62", times = 4),
    rep("#8da0cb", times = 2),
    rep("#e78ac3", times = 5),
    rep("#a6d854", times = 4),
    rep("#ffd92f", times = 2),
    rep("#e5c494", times = 4)
  )
)
rownames(ordered_df) <- ordered_df$group

Disease_list <- data.frame(
  group = c(
    "General health", "Inflammatory Bowel Disease (IBD)", "Irritable Bowel Syndrome (IBS)",
    "Liver cirrhosis", "Type 2 Diabetes (T2D)", "Dyslipidemia", "Hypertension",
    "Hyperuricemia", "Ischemic Heart Disease (IHD)", "Heart failure", "Stroke",
    "Depression", "Rheumatoid arthritis", "Collagen disease",
    "Asthma", "Chronic Obstructive Pulmonary Disease (COPD)"
  ),
  color = c("white", rep("black", 15))
)

sankeywidth  <- 900
sankeyheight <- 300


causal <- read.xlsx("Supplementary Tables_260405.xlsx",
                    sheet = "S9 MOTU",
                    check.names = FALSE)

causal$ori <- causal$`Mediator GTDB`
colnames(causal)[6] <- "Mediator"


metadata <- c("Yogurt", "Kimchi", "Pickles", "Natto", "Miso")

sp_list <- c(
  "Faecalibacterium prausnitzii_D [ID:06108]",
  "Adlercreutzia equolifaciens [ID:18084]",
  "Adlercreutzia celatus_A [ID:15443]"
)

causal <- causal[causal$Mediator %in% sp_list, ]
causal <- causal[causal$Exposure %in% metadata, ]

causal$Mediator <- gsub("\\[ID:(\\d+)\\]", "\\1", causal$Mediator)
sp_list <- gsub("\\[ID:(\\d+)\\]", "\\1", sp_list)


condi <- "newfig4b_formenb"

nodes <- data.frame()

nodes <- rbind(nodes, data.frame(
  id = 0:(length(metadata)-1),
  tag = metadata,
  group = ordered_df[metadata, ]$annotation
))

nodes <- rbind(nodes, data.frame(
  id = (0:(length(sp_list)-1)) + nrow(nodes),
  tag = sp_list,
  group = "all_nodes"
))

disease <- Disease_list$group
disease <- disease[disease %in% unique(causal$Outcome)]

nodes <- rbind(nodes, data.frame(
  id = (0:(length(disease)-1)) + nrow(nodes),
  tag = disease,
  group = ifelse(disease == "General health", "Health", "Disease")
))

# disease short name
disease_display <- sapply(disease, function(x){
  if (grepl("\\(.*\\)", x)) {
    substr(x, regexpr("\\(", x) + 1, regexpr("\\)", x) - 1)
  } else x
})

name_map <- c(
  "Vegetables"="Vegetables","Fruits"="Fruits","Mushrooms"="Mushrooms",
  "Coffee"="Coffee","Green tea"="Green tea","Vinegar"="Vinegar",
  "Tofu"="Tofu","Natto"="Natto","Miso"="Miso",
  "Pickles"="Pickles","Kimchi"="Kimchi","Yogurt"="Yogurt",
  "Milk"="Milk","Meat"="Meat","Processed meat"="Processed meat",
  "Seafood"="Seafood","Eggs"="Eggs","Dressing"="Dressing",
  "Rice"="Rice","Bread"="Bread","Noodles"="Noodles",
  "Soft drinks"="Soft drinks","Alcohol"="Alcohol","Smoking"="Smoking",
  "Strong physical activity"="Strong physical activity",
  "Moderate physical activity"="Moderate physical activity",
  "Weak physical activity"="Weak physical activity",
  "Sitting down ≥ 9.5h"="Sitting down ≥ 9.5h"
)

nodes$display_tag <- ifelse(
  nodes$tag %in% names(name_map),
  name_map[nodes$tag],
  disease_display[match(nodes$tag, disease)]
)


links <- data.frame()

for(i in metadata){
  for(j in sp_list){
    temp <- causal[(causal$Exposure==i)&(causal$EXP_coef>0)&(causal$Mediator==j),]
    if(nrow(temp)>0){
      links <- rbind(links, data.frame(
        source=i, target=j, val=nrow(temp),
        ids=nodes$id[nodes$tag==i],
        idt=nodes$id[nodes$tag==j],
        group="Plus"
      ))
    }

    temp <- causal[(causal$Exposure==i)&(causal$EXP_coef<0)&(causal$Mediator==j),]
    if(nrow(temp)>0){
      links <- rbind(links, data.frame(
        source=i, target=j, val=nrow(temp),
        ids=nodes$id[nodes$tag==i],
        idt=nodes$id[nodes$tag==j],
        group="Minus"
      ))
    }
  }
}

for(i in sp_list){
  for(j in disease){
    temp <- causal[(causal$Outcome==j)&(causal$Dis_coef>0)&(causal$Mediator==i),]
    if(nrow(temp)>0){
      links <- rbind(links, data.frame(
        source=i, target=j, val=nrow(temp),
        ids=nodes$id[nodes$tag==i],
        idt=nodes$id[nodes$tag==j],
        group="Plus"
      ))
    }

    temp <- causal[(causal$Outcome==j)&(causal$Dis_coef<0)&(causal$Mediator==i),]
    if(nrow(temp)>0){
      links <- rbind(links, data.frame(
        source=i, target=j, val=nrow(temp),
        ids=nodes$id[nodes$tag==i],
        idt=nodes$id[nodes$tag==j],
        group="Minus"
      ))
    }
  }
}

rownames(nodes) <- NULL
rownames(links) <- NULL


p <- sankeyNetwork(
  Links=links, Nodes=nodes,
  Source="ids", Target="idt",
  Value="val",
  NodeID="display_tag",
  LinkGroup="group",
  NodeGroup="group",
  fontSize=16,
  fontFamily="helvetica",
  iterations=0,
  sinksRight=FALSE,
  width=sankeywidth,
  height=sankeyheight,
  nodeWidth=2
)

p <- onRender(p, 'function(el,x){
  d3.selectAll(".node text").style("font-weight","bold");
}')

p <- htmlwidgets::prependContent(
  p,
  htmltools::tags$h1(condi, style="text-align:center;")
)

saveNetwork(p, "fig4b_down.html")
