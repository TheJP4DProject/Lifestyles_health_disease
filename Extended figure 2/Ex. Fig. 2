make_cell_maa <- function(qmat, pmat){
function(j,i,x,y,width,height,fill){
q <- qmat[i,j]; p <- pmat[i,j]
if(!is.na(q) && q < 0.05)
grid.text("**",x,y,vjust=0.8,gp=gpar(fontsize=5))
else if(!is.na(p) && p < 0.1)
grid.text("*", x,y,vjust=0.8,gp=gpar(fontsize=5))
}
}

